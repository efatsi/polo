<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Crozet Polo" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/soccer-ball.png" type="image/png">
    <link rel="apple-touch-icon" href="/soccer-ball.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <main class="container mx-auto mt-28 px-5 flex" data-controller="hello">
      <%= yield %>
    </main>
  </body>
</html>
